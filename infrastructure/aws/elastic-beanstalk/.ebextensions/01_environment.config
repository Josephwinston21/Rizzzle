option_settings:
  aws:elasticbeanstalk:application:environment:
    DB_USERNAME: admin
    DB_PASSWORD: password
    DB_HOST: your-db-endpoint
    DB_PORT: 3306


% infrastructure/aws/elastic-beanstalk/.ebextensions/01_environment.config
% Custom Changes:
% Database Credentials: Replace DB_USERNAME, DB_PASSWORD, DB_HOST, and DB_PORT with your database credentials.
